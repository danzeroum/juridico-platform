{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://juridico-platform/schemas/alert.v1.json",
  "title": "AlertEnvelope",
  "description": "Contrato neutro de linguagem para alertas. Validado tanto pelo publisher Python quanto pelo consumidor Elixir/Oban. Versionado: mudancas incompativeis criam alert.v2.json.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "alert_id",
    "dedup_key",
    "rule_id",
    "severity",
    "channels",
    "occurred_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "alerts/v1" },
    "alert_id": { "type": "string", "minLength": 1 },
    "dedup_key": { "type": "string", "minLength": 1 },
    "rule_id": { "type": "string", "minLength": 1 },
    "severity": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
    "subject_ref": {
      "type": "object",
      "description": "Somente referencias nao pessoais (ex.: municipio_ibge, cnpj).",
      "additionalProperties": { "type": "string" }
    },
    "payload": { "type": "object" },
    "channels": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["webhook", "email", "slack", "whatsapp"] }
    },
    "occurred_at": { "type": "string", "format": "date-time" },
    "enrichment": { "type": "boolean", "default": false }
  }
}
