# =============================================================================
# PLATAFORMA JURIDICO-CONTABIL - Variaveis de Ambiente
# Copiar para .env e preencher com valores reais
# NUNCA commitar .env com valores reais
# =============================================================================

# PostgreSQL — usuário admin (dono do banco; NÃO usar para conexões da aplicação)
POSTGRES_USER=juridico
POSTGRES_PASSWORD=TROQUE_SENHA_FORTE
POSTGRES_DB=juridico_platform

# app_user — role não-superusuário usado pela aplicação (gateway, scoring).
# CRÍTICO: a RLS (FORCE ROW LEVEL SECURITY) é bypassada silenciosamente se a
# aplicação conectar como superusuário. POSTGRES_USER=juridico é owner/superuser.
# Use APP_USER_PASSWORD em DATABASE_URL dos serviços de aplicação.
# Em produção: docker secret create APP_USER_PASSWORD <(openssl rand -hex 32)
APP_USER_PASSWORD=TROQUE_SENHA_FORTE

# PgBouncer
PGBOUNCER_POOL_SIZE=20
PGBOUNCER_MAX_CLIENT_CONN=1000

# Neo4j
NEO4J_PASSWORD=TROQUE_SENHA_FORTE

# Redis
REDIS_PASSWORD=TROQUE_SENHA_FORTE

# MinIO
MINIO_USER=admin
MINIO_PASSWORD=TROQUE_SENHA_FORTE

# LLM
LLM_API_KEY=sk-TROQUE_API_KEY
LLM_MODEL_PRIMARY=gpt-4o
LLM_MODEL_FAST=gpt-4o-mini
LLM_MODEL_LOCAL=llama3:8b

# JWT
JWT_SECRET=TROQUE_SECRET_FORTE_256BITS
JWT_EXPIRY_HOURS=24

# Traefik / TLS
LETSENCRYPT_EMAIL=seu@email.com
DOMAIN=seudominio.com.br

# Grafana
GRAFANA_PASSWORD=TROQUE_SENHA_FORTE

# DATAJUD
DATAJUD_API_URL=https://api-publica.datajud.cnj.jus.br
DATAJUD_TOKEN=APIKeyPublica

# Alertas
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
ALERT_EMAIL=ops@seudominio.com.br

# FiscalEngine (NCM/ICMS) — worker fiscal
# Reusa DATABASE_URL, REDIS_URL, MINIO_*, OLLAMA_URL. Específicos (opcionais) abaixo.
TIPI_CSV_URL=https://www.gov.br/receitafederal/pt-br/centrais-de-conteudo/publicacoes/tipi/tipi.csv
# Chromium (SEFAZ) e Tesseract (CONFAZ OCR) são instalados na imagem services/fiscal/Dockerfile.
# Em outros ambientes, aponte o binário do Chromium se necessário:
# PLAYWRIGHT_EXECUTABLE=/opt/pw-browsers/chromium
